# ============== LLM Provider ==============
# 默认 volcengine（火山方舟豆包系列，OpenAI 兼容）；可选 anthropic
LLM_PROVIDER=volcengine

# ---- Volcengine 方舟（豆包/Kimi/GLM/MiniMax/DeepSeek 等都走这个网关）----
# 必填（当 LLM_PROVIDER=volcengine 时）。从 https://console.volcengine.com/ark 获取
VOLCENGINE_API_KEY=请填你的火山方舟 API Key
VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3

# ---- Anthropic（仅当 LLM_PROVIDER=anthropic 时必填）----
ANTHROPIC_API_KEY=

# ---- 通用 LLM 参数 ----
# 默认 doubao-seed-2.0-pro（128K 上下文，通用）
# 其他可选：ark-code-latest / doubao-seed-2.0-code / doubao-seed-2.0-lite
#          / kimi-k2.5 / glm-4.7 / deepseek-v3.2 / minimax-m2.5
# 切回 Anthropic 时改成 claude-sonnet-4-6
LLM_MODEL=doubao-seed-2.0-pro
LLM_TEMPERATURE=0.2

# ============== Embedding ==============
# 中文友好 embedding 模型（本地，sentence-transformers 自动下载）
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# ============== Vector Store ==============
CHROMA_PERSIST_DIR=chroma_db
CHROMA_COLLECTION=docs

# ============== Server ==============
SERVER_PORT=8004
DOCS_DIR=data
