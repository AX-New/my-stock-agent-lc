# ============== Anthropic ==============
# 必填。Claude API Key。
ANTHROPIC_API_KEY=sk-ant-xxxx

# 可选。LLM 模型名，默认 claude-sonnet-4-6。
LLM_MODEL=claude-sonnet-4-6

# 可选。LLM 温度，默认 0.2（学习项目偏向稳定输出）。
LLM_TEMPERATURE=0.2

# ============== Embedding ==============
# 中文友好 embedding 模型（本地，sentence-transformers 自动下载）。
# 默认 BAAI/bge-small-zh-v1.5，约 100MB。
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# ============== Vector Store ==============
# Chroma 持久化目录（相对项目根）。
CHROMA_PERSIST_DIR=chroma_db

# 集合名（同一目录可放多个 collection）。
CHROMA_COLLECTION=docs

# ============== Server ==============
# FastAPI 监听端口。
SERVER_PORT=8004

# 文档目录（ingest 脚本会扫这个目录里所有 .md / .txt）。
DOCS_DIR=data
